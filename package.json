{
  "name": "webtorrent-p2p-stream-app",
  "version": "1.0.0",
  "description": "Browser-based P2P video streaming app spec and execution plan using WebTorrent + WebRTC.",
  "private": true,
  "scripts": {
    "dev": "concurrently -n server,client -c cyan,green \"npm run dev --prefix server\" \"npm run dev --prefix client\"",
    "dev:server": "npm run dev --prefix server",
    "dev:client": "npm run dev --prefix client",
    "build": "npm run build --prefix client",
    "test:policy": "node --test client/test/*.test.mjs",
    "start": "npm run start --prefix server",
    "validate:report": "node scripts/evaluate-validation-report.js",
    "validate:relay": "node scripts/evaluate-validation-report.js --require-relay",
    "video:normalize": "node scripts/normalize-video.js",
    "smoke:m2m5m6m7": "node scripts/smoke-m2-m5-m6-m7.js",
    "smoke:m8m15": "node scripts/smoke-m8-m15.js",
    "smoke:m14": "node scripts/smoke-m14-security.js",
    "smoke:m12": "node scripts/smoke-m12-reconnect.js",
    "smoke:all": "npm run smoke:m2m5m6m7 && npm run smoke:m8m15 && npm run smoke:m14 && npm run smoke:m12",
    "verify:all": "npm run test:policy && npm run build --prefix client && npm run smoke:all"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/atikulmunna/webtorrent-p2p-stream-app.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/atikulmunna/webtorrent-p2p-stream-app/issues"
  },
  "homepage": "https://github.com/atikulmunna/webtorrent-p2p-stream-app#readme",
  "devDependencies": {
    "concurrently": "^9.2.1"
  },
  "dependencies": {
    "socket.io-client": "^4.8.3"
  }
}
